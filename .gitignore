# Generated by Cargo
# will have compiled files and executables
debug
target

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# rustc will dump stack traces when hitting an internal compiler error to PWD
rustc-ice-*.txt

# For temporary files/folders that shouldn't be committed
*.local.*

# OS
.DS_Store
Thumbs.db

# Claude
# Ignore everything inside the .claude directory
.claude/**/*

# Allow specific configuration and rule files
!.claude/CLAUDE.md
!.claude/settings.json
!.claude/rules/

# Env
.env
.env.*
!.env.example
!.env.test

# SQLite
# Ignore the actual database files (common extensions)
*.sqlite
*.sqlite3
*.db
*.db3

# Ignore SQLite journal files (created during transactions)
*.sqlite-journal
*.sqlite3-journal
*.db-journal

# Ignore SQLite Write-Ahead Log (WAL) files
*.sqlite-wal
*.sqlite-shm
*.sqlite3-wal
*.sqlite3-shm
*.db-wal
*.db-shm

# Ignore SQL dumps or backup files
*.sql
*.bak
